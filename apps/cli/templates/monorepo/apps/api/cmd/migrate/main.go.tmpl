package main

import (
	"context"
	"os"
	"os/signal"
	"time"

	"{{MODULE_PATH}}/internal/infrastructure/config"
	"{{MODULE_PATH}}/internal/infrastructure/database"
	"{{MODULE_PATH}}/internal/infrastructure/logger"
)

const DefaultTimeout = 60 * time.Second

func main() {
	cfg, err := config.LoadConfig()
	if err != nil {
		panic("failed to load config: " + err.Error())
	}

	log := logger.NewLogger(cfg.Observability)

	timeout := cfg.Seeder.Timeout
	if timeout == 0 {
		timeout = DefaultTimeout
	}

	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt)
	defer stop()

	migrateCtx, cancel := context.WithTimeout(ctx, timeout)
	defer cancel()

	if err := database.Migrate(migrateCtx, &log, cfg); err != nil {
		log.Fatal().Err(err).Msg("failed to migrate database")
	}

	log.Info().Msg("database migrations completed")
}
